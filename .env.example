# Google Sheets CMS Configuration
# Copy this file to .env.local and fill in your values

# The ID from your Google Sheet URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Service account email (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key from the service account JSON file
# Copy the entire "private_key" value including -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY-----
# Keep the \n characters as-is (don't convert to actual newlines)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Optional: Sheet name (defaults to "Menu")
GOOGLE_SHEETS_MENU_SHEET_NAME=Menu

# Optional: Cache revalidation time in seconds (defaults to 60)
MENU_REVALIDATE_SECONDS=60
